    "DELETE /contacts/{contact_id} - Delete contact",
    "POST /fixed-assets - Create fixed asset",
    "GET /fixed-assets - List fixed assets",
    "GET /fixed-assets/{fixed_asset_id} - Get fixed asset by ID",
